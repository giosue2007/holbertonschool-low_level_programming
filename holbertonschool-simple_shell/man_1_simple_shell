.SH EXAMPLES
Mode interactif:
.PP
.B ./hsh
.br
#cisfun$ ls -l
.br
#cisfun$ env
.br
#cisfun$ exit

Mode non interactif:
.PP
.B echo "/bin/ls" | ./hsh
